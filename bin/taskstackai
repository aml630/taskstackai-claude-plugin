}

# ── Export / Import ──────────────────────────────────────────────────────────

cmd_export() {
    local json_flag=false
    [[ "${1:-}" == "--json" ]] && json_flag=true

    echo "Exporting all issues..."
    local page=1 total=0
    local all_items="[]"

    while true; do
        local result
        result=$(_get "/issues?page=${page}&pageSize=100")
        local items count
        items=$(echo "$result" | _jq '.items')
        count=$(echo "$items" | _jq 'length')
        total=$(echo "$result" | _jq '.totalCount')

        if [[ "$count" == "0" ]]; then
            break
        fi

        all_items=$(echo "$all_items $items" | _jq -s '.[0] + .[1]')
        page=$((page + 1))
    done

    if $json_flag; then
        echo "$all_items" | _jq '.'
    else
        local bss_dir
        bss_dir=$(_config_dir)
        local export_file="$bss_dir/export-$(date +%Y%m%d-%H%M%S).json"
        echo "$all_items" | _jq '.' > "$export_file"
        echo "✓ Exported $total issues to $export_file"
    fi
}

cmd_import() {
    local file="${1:-}"

    if [[ -z "$file" || ! -f "$file" ]]; then
        echo "Usage: taskstackai import <file.json>" >&2; return 1
    fi

    local count
    count=$(_jq 'length' < "$file")
    echo "Importing $count issues from $file..."

    _jq -c '.[]' < "$file" | while read -r issue; do
        local title type priority desc
        title=$(echo "$issue" | _jq -r '.title')
        type=$(echo "$issue" | _jq -r '.type // "task"')
        priority=$(echo "$issue" | _jq -r '.priority // 2')
        desc=$(echo "$issue" | _jq -r '.description // ""')

        local body
        body=$(_jq -n \
            --arg t "$title" --arg d "$desc" --arg ty "$type" --argjson p "$priority" \
            '{title: $t, description: $d, type: $ty, priority: $p}')

        _post "/issues" -d "$body" >/dev/null 2>&1
        echo "  ✓ $title"
    done
    echo "✓ Import complete"
}

# ── Project member commands ───────────────────────────────────────────────────

cmd_project() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        members)  cmd_project_members "$@" ;;
        invite)   cmd_project_invite "$@" ;;
        --help|-h|help)
            echo "Usage: taskstackai project <members|invite> ..."
            echo ""
            echo "  taskstackai project members [--project <id>]                          List project members"
            echo "  taskstackai project invite <email> --display-name <name> [--role <role>] [--project <id>]  Invite member"
            ;;
        *) echo "Unknown project subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_project_members() {
    local json_flag=false project_override=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)      json_flag=true; shift ;;
            --project)   project_override="$2"; shift 2 ;;
            --help|-h)   echo "Usage: taskstackai project members [--project <id>] [--json]"; return 0 ;;
            *)           shift ;;
        esac
    done

    local project_id
    project_id=$(_resolve_project_id "$project_override") || return 1

    local result
    result=$(_get "/projects/${project_id}/members")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Project Members:"
        echo ""
        printf "  %-24s %-30s %-10s %s\n" "NAME" "EMAIL" "ROLE" "JOINED"
        printf "  %-24s %-30s %-10s %s\n" "────────────────────────" "──────────────────────────────" "──────────" "──────────"
        echo "$result" | _jq -r '.[]? | "  " + (.displayName | if length > 24 then .[:21] + "..." else . + (" " * (24 - length)) end) + " " + (.email | if length > 30 then .[:27] + "..." else . + (" " * (30 - length)) end) + " " + (.role | . + (" " * (10 - length))) + " " + (.joinedAt | split("T")[0])' 2>/dev/null
        local count
        count=$(echo "$result" | _jq 'length // 0')
        echo ""
        echo "Total: $count members"
    fi
}

cmd_project_invite() {
    local email="" display_name="" role="Member" project_override="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --display-name) display_name="$2"; shift 2 ;;
            --role)         role="$2"; shift 2 ;;
            --project)      project_override="$2"; shift 2 ;;
            --json)         json_flag=true; shift ;;
            --help|-h)      echo "Usage: taskstackai project invite <email> --display-name <name> [--role member|admin|viewer] [--project <id>] [--json]"; return 0 ;;
            *)
                if [[ -z "$email" ]]; then
                    email="$1"
                fi
                shift ;;
        esac
    done

    if [[ -z "$email" ]]; then
        echo "Error: Email address required" >&2; return 1
    fi
    if [[ -z "$display_name" ]]; then
        echo "Error: --display-name is required" >&2; return 1
    fi

    local project_id
    project_id=$(_resolve_project_id "$project_override") || return 1

    local body
    body=$(_jq -n \
        --arg email "$email" \
        --arg displayName "$display_name" \
        --arg role "$role" \
        '{email: $email, displayName: $displayName, role: $role}')

    local result
    result=$(_post "/projects/${project_id}/members/invite" -d "$body")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        local name
        name=$(echo "$result" | _jq -r '.displayName // "user"')
        local assigned_role
        assigned_role=$(echo "$result" | _jq -r '.role // "Member"')
        echo "✓ Invited $email ($name) as $assigned_role"
    fi
}

