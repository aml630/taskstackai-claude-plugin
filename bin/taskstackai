    local result
    result=$(_post "/wisps" -d "$body") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '"✓ Created wisp " + .id + " from " + (.sourceMoleculeId // "unknown") + " (" + (.totalSteps|tostring) + " steps)"'
}

