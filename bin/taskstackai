}

# ── API Key management ───────────────────────────────────────────────────────

cmd_apikey() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list)    cmd_apikey_list "$@" ;;
        create)  cmd_apikey_create "$@" ;;
        delete)  cmd_apikey_delete "$@" ;;
        --help|-h|help)
            echo "Usage: taskstackai apikey <list|create|delete>"
            echo ""
            echo "  taskstackai apikey list                       List API keys"
            echo "  taskstackai apikey create <label> [scopes]    Create new key"
            echo "  taskstackai apikey delete <id>                 Delete key"
            ;;
        *) echo "Unknown apikey subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_apikey_list() {
    local json_flag=false
    [[ "${1:-}" == "--json" ]] && json_flag=true

    local result
    result=$(_get "/auth/api-keys")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "API Keys:"
        echo "$result" | _jq -r '.[]? | "  [" + .id + "] " + .label + " — scopes: " + .scopes + (if .expiresAt then " (expires: " + .expiresAt + ")" else "" end)' 2>/dev/null || echo "  (none)"
    fi
}

cmd_apikey_create() {
    local label="${1:-}" scopes="${2:-issues:read,issues:write}"

    if [[ -z "$label" ]]; then
        echo "Usage: taskstackai apikey create <label> [scopes]" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg l "$label" --arg s "$scopes" '{label: $l, scopes: $s}')

    local result
    result=$(_post "/auth/api-keys" -d "$body")

    echo "✓ API Key created:"
    echo "$result" | _jq -r '"  Key: " + .rawKey + "\n  ID: " + .id + "\n  ⚠  Save this key — it will not be shown again."' 2>/dev/null
}

cmd_apikey_delete() {
    local id="${1:-}"

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai apikey delete <key-id>" >&2; return 1
    fi

    _delete "/auth/api-keys/$id" >/dev/null
    echo "✓ Deleted API key $id"
}

# ── Molecule commands ─────────────────────────────────────────────────────────

cmd_mol() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list)      cmd_mol_list "$@" ;;
        show)      cmd_mol_show "$@" ;;
        pour)      cmd_mol_pour "$@" ;;
        templates) cmd_mol_templates "$@" ;;
        create)    cmd_mol_create "$@" ;;
        delete)    cmd_mol_delete "$@" ;;
        progress)  cmd_mol_progress "$@" ;;
        wisp)      cmd_mol_wisp "$@" ;;
        squash)    cmd_mol_squash "$@" ;;
        burn)      cmd_mol_burn "$@" ;;
        wisps)     cmd_mol_wisps "$@" ;;
        distill)   cmd_mol_distill "$@" ;;
        --help|-h|help)
            cat <<'EOF'
Usage: taskstackai mol <subcommand> [options]

  list                   List molecules (workflows)
  show <id>              Show molecule detail
  create                 Create a new molecule
  pour                   Instantiate a molecule from a template
  templates              List available templates
  progress <id>          Show molecule progress with wave breakdown
  delete <id>            Delete a molecule
  wisp <id>              Create ephemeral wisp from a molecule
  squash <wisp-id>       Squash wisp back into source (merge progress)
  burn <wisp-id>         Burn (delete) wisp without merging
  wisps                  List active wisps
  distill                Distill template from epic/molecule
EOF
            ;;
        *) echo "Unknown mol subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_mol_list() {
    local json_flag=false type="" phase="" status=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --type)    type="$2"; shift 2 ;;
            --phase)   phase="$2"; shift 2 ;;
            --status)  status="$2"; shift 2 ;;
            --help|-h) echo "Usage: taskstackai mol list [--type <work|swarm|patrol>] [--phase <proto|mol|wisp>] [--status <open|completed>] [--json]"; return 0 ;;
            *)         shift ;;
        esac
    done

    local qs=""
    [[ -n "$type" ]]   && qs="${qs}&type=$type"
    [[ -n "$phase" ]]  && qs="${qs}&phase=$phase"
    [[ -n "$status" ]] && qs="${qs}&status=$status"
    qs="${qs#&}"

    local path="/molecules"
    [[ -n "$qs" ]] && path="${path}?${qs}"

    local result
    result=$(_get "$path") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '
        if .items then
            (.items[] |
                (if .status == "open" then "○"
                 elif .status == "in_progress" then "◐"
                 elif .status == "completed" then "✓"
                 else "?" end) + " " +
                .id + " [" + .moleculeType + "/" + .phase + "] " +
                .title +
                " (" + (.completedSteps|tostring) + "/" + (.totalSteps|tostring) + " steps)"
            ),
            "",
            "Total: " + (.totalCount|tostring) + " molecules"
        else
            "No molecules found."
        end'
}

cmd_mol_show() {
    local id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai mol show <id> [--json]"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai mol show <id>" >&2; return 1
    fi

    local result
    result=$(_get "/molecules/$id") || { echo "Molecule '$id' not found." >&2; return 1; }

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '
        "╔══════════════════════════════════════════════════════════════",
        "║ Molecule: " + .title,
        "╠══════════════════════════════════════════════════════════════",
        "║ ID:       " + .id,
        "║ Type:     " + .moleculeType,
        "║ Phase:    " + .phase,
        "║ Status:   " + .status,
        "║ Progress: " + (.completedSteps|tostring) + "/" + (.totalSteps|tostring) +
            " (" + (.completionPercent|tostring) + "%)",
        (if .assigneeName then "║ Assignee: " + .assigneeName else empty end),
        (if .epicIssueId then "║ Epic:     " + .epicIssueId else empty end),
        "║ Created:  " + .createdAt,
        "╠══ Steps ═════════════════════════════════════════════════════",
        (.steps // [] | sort_by(.wave, .sortOrder)[] |
            "║  W" + (.wave|tostring) + " " +
            (if .issueStatus == "closed" then "✓"
             elif .issueStatus == "in_progress" then "◐"
             else "○" end) + " " +
            .issueId + " " + .issueTitle +
            (if (.dependsOnStepIds | length) > 0 then
                " (deps: " + ([.dependsOnStepIds[] | tostring] | join(",")) + ")"
            else "" end)
        ),
        "╚══════════════════════════════════════════════════════════════"'
}

cmd_mol_create() {
    local title="" description="" mol_type="work"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title)       title="$2"; shift 2 ;;
            --description) description="$2"; shift 2 ;;
            --type)        mol_type="$2"; shift 2 ;;
            --help|-h)     echo "Usage: taskstackai mol create --title <title> [--description <desc>] [--type <work|swarm|patrol>]"; return 0 ;;
            *)             shift ;;
        esac
    done

    if [[ -z "$title" ]]; then
        echo "Usage: taskstackai mol create --title <title>" >&2; return 1
    fi

    local body
    body=$(printf '{"title":"%s","description":%s,"moleculeType":"%s"}' \
        "$title" \
        "$(if [[ -n "$description" ]]; then printf '"%s"' "$description"; else echo null; fi)" \
        "$mol_type")

    local result
    result=$(_post "/molecules" -d "$body") || return 1
    echo "$result" | _jq -r '"✓ Created molecule " + .id + " - " + .title'
}

cmd_mol_delete() {
    local id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) echo "Usage: taskstackai mol delete <id>"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai mol delete <id>" >&2; return 1
    fi

    _delete "/molecules/$id" >/dev/null || { echo "Failed to delete molecule." >&2; return 1; }
    echo "✓ Deleted molecule $id"
}

cmd_mol_pour() {
    local template_id="" project_id="" anchor_date="" json_flag=false
    local -a vars=() roles=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --template)    template_id="$2"; shift 2 ;;
            --project)     project_id="$2"; shift 2 ;;
            --anchor-date) anchor_date="$2"; shift 2 ;;
            --var)         vars+=("$2"); shift 2 ;;
            --role)        roles+=("$2"); shift 2 ;;
            --json)        json_flag=true; shift ;;
            --help|-h)
                cat <<'EOF'
Usage: taskstackai mol pour --template <id> [options]

Options:
  --template <id>       Template to instantiate (required)
  --project <id>        Target project (default: active)
  --anchor-date <date>  Anchor date for due date offsets (ISO 8601)
  --var <key=value>     Variable substitution (repeatable)
  --role <role=userId>  Role assignment (repeatable)
  --json                Output raw JSON
EOF
                return 0
                ;;
            *)             shift ;;
        esac
    done

    if [[ -z "$template_id" ]]; then
        echo "Usage: taskstackai mol pour --template <id>" >&2; return 1
    fi

    # Build JSON body
    local vars_json="{}"
    for v in "${vars[@]}"; do
        local key="${v%%=*}" val="${v#*=}"
        vars_json=$(echo "$vars_json" | _jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
    done

    local roles_json="{}"
    for r in "${roles[@]}"; do
        local key="${r%%=*}" val="${r#*=}"
        roles_json=$(echo "$roles_json" | _jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
    done

    local body
    body=$(_jq -n \
        --arg tid "$template_id" \
        --arg pid "$project_id" \
        --arg ad "$anchor_date" \
        --argjson vars "$vars_json" \
        --argjson roles "$roles_json" \
        '{templateId: $tid, variables: $vars, roleAssignments: $roles} +
         (if $pid != "" then {projectId: $pid} else {} end) +
         (if $ad != "" then {anchorDate: $ad} else {} end)')

    local result
    result=$(_post "/molecules/pour" -d "$body") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '"✓ Poured molecule " + .id + " - " + .title + " (" + (.totalSteps|tostring) + " steps)"'
}

cmd_mol_templates() {
    local json_flag=false type=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --type)    type="$2"; shift 2 ;;
            --help|-h) echo "Usage: taskstackai mol templates [--type <work|swarm|patrol>] [--json]"; return 0 ;;
            *)         shift ;;
        esac
    done

    local path="/molecule-templates"
    [[ -n "$type" ]] && path="${path}?type=$type"

    local result
    result=$(_get "$path") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '
        if .items then
            (.items[] |
                .id + " [" + .moleculeType + "] " + .name + " - " + .title +
                " (" + (.stepCount|tostring) + " steps)" +
                (if .isBuiltIn then " ★" else "" end)
            ),
            "",
            "Total: " + (.totalCount|tostring) + " templates"
        else
            "No templates found."
        end'
}

cmd_mol_progress() {
    local id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai mol progress <id> [--json]"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai mol progress <id>" >&2; return 1
    fi

    local result
    result=$(_get "/molecules/$id/progress") || { echo "Molecule '$id' not found." >&2; return 1; }

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '
        "Progress for molecule " + .moleculeId,
        "  Total:      " + (.totalSteps|tostring) + " steps",
        "  Completed:  " + (.completedSteps|tostring),
        "  In Progress:" + (.inProgressSteps|tostring),
        "  Blocked:    " + (.blockedSteps|tostring),
        "  Completion: " + (.completionPercent|tostring) + "%",
        (if .stepsPerHour then "  Velocity:   " + (.stepsPerHour|tostring) + " steps/hour" else empty end),
        (if .estimatedCompletion then "  ETA:        " + .estimatedCompletion else empty end),
        "",
        "Waves:",
        (.waves // [] | .[] |
            "  Wave " + (.waveNumber|tostring) + ": " +
            (.completedSteps|tostring) + "/" + (.totalSteps|tostring) + " completed"
        )'
}

cmd_mol_distill() {
    local source_id="" source_type="epic" name="" description="" json_flag=false
    local -a vars=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --source)      source_id="$2"; shift 2 ;;
            --source-type) source_type="$2"; shift 2 ;;
            --name)        name="$2"; shift 2 ;;
            --description) description="$2"; shift 2 ;;
            --var)         vars+=("$2"); shift 2 ;;
            --json)        json_flag=true; shift ;;
            --help|-h)
                cat <<'EOF'
Usage: taskstackai mol distill --source <id> --name <name> [options]

Options:
  --source <id>          Source epic or molecule ID (required)
  --source-type <type>   "epic" or "molecule" (default: epic)
  --name <name>          Template name (required)
  --description <desc>   Template description
  --var <find=varName>   Variable substitution (repeatable)
  --json                 Output raw JSON
EOF
                return 0
                ;;
            *)             shift ;;
        esac
    done

    if [[ -z "$source_id" || -z "$name" ]]; then
        echo "Usage: taskstackai mol distill --source <id> --name <name>" >&2; return 1
    fi

    # Build variables array
    local vars_json="[]"
    for v in "${vars[@]}"; do
        local find="${v%%=*}" var_name="${v#*=}"
        vars_json=$(echo "$vars_json" | _jq --arg f "$find" --arg v "$var_name" '. + [{"find": $f, "varName": $v}]')
    done

    local body
    body=$(_jq -n \
        --arg sid "$source_id" \
        --arg st "$source_type" \
        --arg nm "$name" \
        --arg desc "$description" \
        --argjson vars "$vars_json" \
        '{sourceId: $sid, sourceType: $st, name: $nm, variables: $vars} +
         (if $desc != "" then {description: $desc} else {} end)')

    local result
    result=$(_post "/distill" -d "$body") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '"✓ Distilled template " + .id + " - " + .name + " (" + (.stepCount|tostring) + " steps, " + ((.variables // []) | length | tostring) + " variables)"'
}

