#!/usr/bin/env bash
# taskstackai - TaskStackAi CLI
# Wraps curl calls to the TaskStackAi REST API for Claude Code integration.
# Config: .taskstackai/config in project root (shell-sourceable key=value)

set -euo pipefail

TASKSTACKAI_VERSION="0.1.0"

# ── Config discovery ─────────────────────────────────────────────────────────

_find_config() {
    local dir="$PWD"
    while [[ "$dir" != "/" && "$dir" != "" ]]; do
        if [[ -f "$dir/.taskstackai/config" ]]; then
            echo "$dir/.taskstackai/config"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    return 1
}

_load_config() {
    local config
    if config=$(_find_config); then
        # shellcheck source=/dev/null
        source "$config"
    else
        if [[ "${1:-}" != "init" && "${1:-}" != "setup" && "${1:-}" != "remove" && "${1:-}" != "version" && "${1:-}" != "help" && "${1:-}" != "--help" ]]; then
            echo "Error: No .taskstackai/config found. Run 'taskstackai setup' first." >&2
            exit 1
        fi
    fi
}

_config_dir() {
    local config
    if config=$(_find_config); then
        dirname "$config"
    else
        echo ".taskstackai"
    fi
}

# ── Project context ──────────────────────────────────────────────────────────

_resolve_project_id() {
    # Accept --project flag override, fall back to config
    local project_id="${1:-${TASKSTACKAI_PROJECT_ID:-}}"
    if [[ -z "$project_id" ]]; then
        echo "Error: No active project. Set TASKSTACKAI_PROJECT_ID in .taskstackai/config or use --project <id>." >&2
        return 1
    fi
    echo "$project_id"
}

# ── API helpers ──────────────────────────────────────────────────────────────

_api() {
    local method="$1" path="$2"
    shift 2
    local server="${TASKSTACKAI_SERVER:-https://taskstackai.com}"
    local url="${server}/api/v1${path}"
    local -a curl_args=(
        -s -S
        -X "$method"
        -H "Authorization: Bearer ${TASKSTACKAI_API_KEY}"
        -H "Content-Type: application/json"
        -H "Accept: application/json"
        --fail-with-body
    )
    curl "${curl_args[@]}" "$@" "$url" 2>/dev/null || {
        local code=$?
        echo "Error: API request failed (curl exit $code)" >&2
        return 1
    }
}

_get()    { _api GET    "$@"; }
_post()   { _api POST   "$@"; }
_patch()  { _api PATCH  "$@"; }
_delete() { _api DELETE "$@"; }

# JSON formatting - use jq if available, otherwise cat
_jq() {
    if command -v jq &>/dev/null; then
        jq "$@"
    else
        cat
    fi
}

# ── Status/Priority formatting ───────────────────────────────────────────────

_status_icon() {
    case "${1:-}" in
        open)        echo "○" ;;
        in_progress) echo "◐" ;;
        closed)      echo "✓" ;;
        deferred)    echo "❄" ;;
        blocked)     echo "●" ;;
        *)           echo "?" ;;
    esac
}

_priority_label() {
    case "${1:-}" in
        0) echo "P0" ;;
        1) echo "P1" ;;
        2) echo "P2" ;;
        3) echo "P3" ;;
        4) echo "P4" ;;
        *) echo "P?" ;;
    esac
}

_format_issue_line() {
    # Expects JSON object on stdin
    _jq -r '"'"$(_status_icon "$(echo)" )"' (.status | if . == "open" then "○" elif . == "in_progress" then "◐" elif . == "closed" then "✓" elif . == "deferred" then "❄" else "●" end) + " " + .id + " ● P" + (.priority|tostring) + " " + .type + " " + .title'
}

_format_issues_table() {
    # Expects JSON array on stdin
    _jq -r '.[] | (.status | if . == "open" then "○" elif . == "in_progress" then "◐" elif . == "closed" then "✓" elif . == "deferred" then "❄" else "●" end) + " " + .id + " ● P" + (.priority|tostring) + " [" + .type + "] " + .title'
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_init() {
    # MVP: init is now an alias for setup
    cmd_setup "$@"
}

cmd_prime() {
    local json_flag=false
    [[ "${1:-}" == "--json" ]] && json_flag=true

    echo "# TaskStackAi Workflow Context"
    echo ""

    # Stats
    echo "## Project Stats"
    _get "/stats" | _jq '.' 2>/dev/null || echo "(stats unavailable)"
    echo ""

    # In-progress work
    echo "## In Progress"
    local ip
    ip=$(_get "/issues?status=in_progress&pageSize=50" 2>/dev/null)
    if [[ -n "$ip" ]]; then
        echo "$ip" | _jq -r '.items[]? | "◐ " + .id + " ● P" + (.priority|tostring) + " [" + .type + "] " + .title' 2>/dev/null || echo "(none)"
    else
        echo "(none)"
    fi
    echo ""

    # Ready work (open, not blocked)
    echo "## Ready to Work"
    local open
    open=$(_get "/issues?status=open&pageSize=50" 2>/dev/null)
    if [[ -n "$open" ]]; then
        echo "$open" | _jq -r '.items[]? | "○ " + .id + " ● P" + (.priority|tostring) + " [" + .type + "] " + .title' 2>/dev/null || echo "(none)"
    else
        echo "(none)"
    fi
    echo ""

    # Recent activity
    echo "## Recent Activity"
    _get "/events?pageSize=5" | _jq -r '.items[]? | .createdAt + " " + .actorId + " " + .action + " " + .issueId' 2>/dev/null || echo "(none)"
    echo ""

    echo "---"
    echo "Commands: taskstackai ready | taskstackai create | taskstackai show <id> | taskstackai close <id>"
    echo "Status: ○ open  ◐ in_progress  ● blocked  ✓ closed  ❄ deferred"
}

cmd_ready() {
    local json_flag=false page=1 page_size=25
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)     json_flag=true; shift ;;
            --page)     page="$2"; shift 2 ;;
            --pageSize) page_size="$2"; shift 2 ;;
            --help|-h)  echo "Usage: taskstackai ready [--json] [--page N] [--pageSize N]"; return 0 ;;
            *)          shift ;;
        esac
    done

    local result
    result=$(_get "/issues?status=open&page=${page}&pageSize=${page_size}")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        local count
        count=$(echo "$result" | _jq '.totalCount // 0')
        echo "Ready to work ($count open issues):"
        echo ""
        echo "$result" | _jq -r '.items[]? | "○ " + .id + " ● P" + (.priority|tostring) + " [" + .type + "] " + .title' 2>/dev/null
        if [[ "$count" == "0" ]]; then
            echo "  (no ready issues)"
        fi
    fi
}

cmd_create() {
    local title="" description="" type="task" priority=2 assignee="" parent=""
    local json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title|-t)       title="$2"; shift 2 ;;
            --description|-d) description="$2"; shift 2 ;;
            --type)           type="$2"; shift 2 ;;
            --priority|-p)    priority="$2"; shift 2 ;;
            --assignee)       assignee="$2"; shift 2 ;;
            --parent)         parent="$2"; shift 2 ;;
            --json)           json_flag=true; shift ;;
            --help|-h)        echo "Usage: taskstackai create --title \"...\" [--type task] [--priority 2] [--description \"...\"] [--assignee id] [--parent id] [--json]"; return 0 ;;
            *)
                # Positional: first is title
                if [[ -z "$title" ]]; then
                    title="$1"
                fi
                shift ;;
        esac
    done

    if [[ -z "$title" ]]; then
        read -rp "Title: " title
    fi

    local body
    body=$(_jq -n \
        --arg title "$title" \
        --arg desc "$description" \
        --arg type "$type" \
        --argjson priority "$priority" \
        --arg assignee "$assignee" \
        --arg parent "$parent" \
        '{title: $title, type: $type, priority: $priority} +
         (if $desc != "" then {description: $desc} else {} end) +
         (if $assignee != "" then {assigneeId: $assignee} else {} end) +
         (if $parent != "" then {parentId: $parent} else {} end)')

    local result
    result=$(_post "/issues" -d "$body")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        local id
        id=$(echo "$result" | _jq -r '.id')
        echo "✓ Created issue: $id — $title"
        echo "  Priority: P${priority}"
        echo "  Type: $type"
        echo "  Status: open"
    fi
}

cmd_show() {
    local id="" json_flag=false long_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --long|-l) long_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai show <id> [--long] [--json]"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Error: Issue ID required" >&2; return 1
    fi

    local result
    result=$(_get "/issues/$id")

    if $json_flag; then
        echo "$result" | _jq '.'
        return 0
    fi

    local title status type priority assignee desc created updated
    title=$(echo "$result" | _jq -r '.title')
    status=$(echo "$result" | _jq -r '.status')
    type=$(echo "$result" | _jq -r '.type')
    priority=$(echo "$result" | _jq -r '.priority')
    assignee=$(echo "$result" | _jq -r '.assigneeId // "unassigned"')
    desc=$(echo "$result" | _jq -r '.description // "(no description)"')
    created=$(echo "$result" | _jq -r '.createdAt')
    updated=$(echo "$result" | _jq -r '.updatedAt')

    local icon
    icon=$(_status_icon "$status")

    echo "$icon $id · $title   [$(_priority_label "$priority") · ${status^^}]"
    echo "Owner: $assignee · Type: $type"
    echo "Created: $created · Updated: $updated"
    echo ""
    echo "DESCRIPTION"
    echo "$desc"

    # Dependencies
    if $long_flag; then
        echo ""
        echo "BLOCKED BY"
        _get "/deps/$id/blocked-by" | _jq -r '.[]? | "  → " + .dependsOnId + ": " + (.dependsOnTitle // "")' 2>/dev/null || echo "  (none)"
        echo ""
        echo "BLOCKS"
        _get "/deps/$id/blocks" | _jq -r '.[]? | "  ← " + .issueId + ": " + (.issueTitle // "")' 2>/dev/null || echo "  (none)"
        echo ""
        echo "COMMENTS"
        _get "/comments/$id" | _jq -r '.[]? | "  " + .authorName + " (" + .createdAt + "): " + .body' 2>/dev/null || echo "  (none)"
        echo ""
        echo "EVENTS"
        _get "/events/issue/$id" | _jq -r '.[]? | "  " + .createdAt + " " + .actorId + " " + .action' 2>/dev/null || echo "  (none)"
    fi
}

cmd_list() {
    local status="" type="" priority="" assignee="" page=1 page_size=25
    local json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)    status="$2"; shift 2 ;;
            --type)      type="$2"; shift 2 ;;
            --priority)  priority="$2"; shift 2 ;;
            --assignee)  assignee="$2"; shift 2 ;;
            --page)      page="$2"; shift 2 ;;
            --pageSize)  page_size="$2"; shift 2 ;;
            --json)      json_flag=true; shift ;;
            --help|-h)   echo "Usage: taskstackai list [--status open] [--type task] [--priority 2] [--assignee id] [--page 1] [--pageSize 25] [--json]"; return 0 ;;
            *)           shift ;;
        esac
    done

    local qs="page=${page}&pageSize=${page_size}"
    [[ -n "$status" ]]   && qs+="&status=$status"
    [[ -n "$type" ]]     && qs+="&type=$type"
    [[ -n "$priority" ]] && qs+="&priority=$priority"
    [[ -n "$assignee" ]] && qs+="&assigneeId=$assignee"

    local result
    result=$(_get "/issues?${qs}")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        local total
        total=$(echo "$result" | _jq '.totalCount // 0')
        echo "$result" | _jq -r '.items[]? | (.status | if . == "open" then "○" elif . == "in_progress" then "◐" elif . == "closed" then "✓" elif . == "deferred" then "❄" else "●" end) + " " + .id + " ● P" + (.priority|tostring) + " [" + .type + "] " + .title'
        echo ""
        echo "Total: $total issues"
        echo "Status: ○ open  ◐ in_progress  ● blocked  ✓ closed  ❄ deferred"
    fi
}

cmd_update() {
    local id="" title="" description="" type="" priority="" assignee=""
    local claim_flag=false json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --title)         title="$2"; shift 2 ;;
            --description)   description="$2"; shift 2 ;;
            --type)          type="$2"; shift 2 ;;
            --priority|-p)   priority="$2"; shift 2 ;;
            --assignee)      assignee="$2"; shift 2 ;;
            --claim)         claim_flag=true; shift ;;
            --json)          json_flag=true; shift ;;
            --help|-h)       echo "Usage: taskstackai update <id> [--title ...] [--description ...] [--type ...] [--priority N] [--assignee id] [--claim] [--json]"; return 0 ;;
            *)               [[ -z "$id" ]] && id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Error: Issue ID required" >&2; return 1
    fi

    if $claim_flag; then
        cmd_claim "$id" $(${json_flag} && echo "--json")
        return $?
    fi

    local body
    body=$(_jq -n \
        --arg title "$title" \
        --arg desc "$description" \
        --arg type "$type" \
        --arg priority "$priority" \
        --arg assignee "$assignee" \
        '(if $title != "" then {title: $title} else {} end) +
         (if $desc != "" then {description: $desc} else {} end) +
         (if $type != "" then {type: $type} else {} end) +
         (if $priority != "" then {priority: ($priority|tonumber)} else {} end) +
         (if $assignee != "" then {assigneeId: $assignee} else {} end)')

    local result
    result=$(_patch "/issues/$id" -d "$body")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "✓ Updated issue: $id"
    fi
}

cmd_close() {
    local reason="" json_flag=false
    local -a ids=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reason)  reason="$2"; shift 2 ;;
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai close <id> [<id2> ...] [--reason \"...\"] [--json]"; return 0 ;;
            *)         ids+=("$1"); shift ;;
        esac
    done

    if [[ ${#ids[@]} -eq 0 ]]; then
        echo "Error: At least one issue ID required" >&2; return 1
    fi

    for id in "${ids[@]}"; do
        local body
        body=$(_jq -n --arg reason "$reason" \
            'if $reason != "" then {reason: $reason} else {} end')

        local result
        result=$(_post "/issues/$id/close" -d "$body")

        if $json_flag; then
            echo "$result" | _jq '.'
        else
            echo "✓ Closed $id"
        fi
    done
}

cmd_reopen() {
    local id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai reopen <id> [--json]"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Error: Issue ID required" >&2; return 1
    fi

    local result
    result=$(_post "/issues/$id/reopen")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "✓ Reopened $id"
    fi
}

cmd_claim() {
    local id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai claim <id> [--json]"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Error: Issue ID required" >&2; return 1
    fi

    # Auto-detect git branch
    local branch=""
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)

    local result
    if [[ -n "$branch" && "$branch" != "HEAD" ]]; then
        result=$(_post "/issues/$id/claim" -d "{\"branchName\":\"$branch\"}")
    else
        result=$(_post "/issues/$id/claim" -d "{}")
    fi

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "✓ Claimed $id (status: in_progress)"
        if [[ -n "$branch" && "$branch" != "HEAD" ]]; then
            echo "  Branch: $branch"
        fi
    fi
}

cmd_search() {
    local query="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai search <query> [--json]"; return 0 ;;
            *)         query="$1"; shift ;;
        esac
    done

    if [[ -z "$query" ]]; then
        echo "Error: Search query required" >&2; return 1
    fi

    local encoded
    encoded=$(printf '%s' "$query" | _jq -sRr @uri 2>/dev/null || echo "$query")

    local result
    result=$(_get "/search?q=${encoded}")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "$result" | _jq -r '.[]? | .id + " " + .title + (if .snippet then "\n  " + .snippet else "" end)' 2>/dev/null
    fi
}

cmd_stats() {
    local json_flag=false
    [[ "${1:-}" == "--json" ]] && json_flag=true

    local result
    result=$(_get "/stats")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "📊 Project Stats"
        echo ""
        echo "$result" | _jq -r 'to_entries[]? | "  " + .key + ": " + (.value|tostring)' 2>/dev/null
    fi
}

cmd_blocked() {
    local json_flag=false
    [[ "${1:-}" == "--json" ]] && json_flag=true

    # Get all open issues, then check which have unresolved blockers
    local result
    result=$(_get "/issues?status=open&pageSize=100")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Blocked Issues:"
        echo ""
        # For each open issue, check if it has unresolved blockers
        echo "$result" | _jq -r '.items[]? | "● " + .id + " ● P" + (.priority|tostring) + " [" + .type + "] " + .title' 2>/dev/null
        echo ""
        echo "(Note: use 'taskstackai show <id> --long' to see blocking dependencies)"
    fi
}

# ── Dependency commands ──────────────────────────────────────────────────────

cmd_dep() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        add)       cmd_dep_add "$@" ;;
        rm|remove) cmd_dep_rm "$@" ;;
        blocks)    cmd_dep_blocks "$@" ;;
        blocked-by) cmd_dep_blocked_by "$@" ;;
        --help|-h|help)
            echo "Usage: taskstackai dep <add|rm|blocks|blocked-by> ..."
            echo ""
            echo "  taskstackai dep add <issue> <depends-on>   Add dependency"
            echo "  taskstackai dep rm <issue> <depends-on>     Remove dependency"
            echo "  taskstackai dep blocks <id>                 What this issue blocks"
            echo "  taskstackai dep blocked-by <id>             What blocks this issue"
            ;;
        *) echo "Unknown dep subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_dep_add() {
    local issue_id="${1:-}" depends_on="${2:-}" json_flag=false
    [[ "${3:-}" == "--json" ]] && json_flag=true

    if [[ -z "$issue_id" || -z "$depends_on" ]]; then
        echo "Usage: taskstackai dep add <issue-id> <depends-on-id>" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg i "$issue_id" --arg d "$depends_on" \
        '{issueId: $i, dependsOnId: $d}')

    local result
    result=$(_post "/deps" -d "$body")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "✓ Added dependency: $issue_id depends on $depends_on"
    fi
}

cmd_dep_rm() {
    local issue_id="${1:-}" depends_on="${2:-}"

    if [[ -z "$issue_id" || -z "$depends_on" ]]; then
        echo "Usage: taskstackai dep rm <issue-id> <depends-on-id>" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg i "$issue_id" --arg d "$depends_on" \
        '{issueId: $i, dependsOnId: $d}')

    _delete "/deps" -d "$body"
    echo "✓ Removed dependency: $issue_id no longer depends on $depends_on"
}

cmd_dep_blocks() {
    local id="${1:-}" json_flag=false
    [[ "${2:-}" == "--json" ]] && json_flag=true

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai dep blocks <id>" >&2; return 1
    fi

    local result
    result=$(_get "/deps/$id/blocks")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Issues blocked by $id:"
        echo "$result" | _jq -r '.[]? | "  ← " + .issueId' 2>/dev/null || echo "  (none)"
    fi
}

cmd_dep_blocked_by() {
    local id="${1:-}" json_flag=false
    [[ "${2:-}" == "--json" ]] && json_flag=true

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai dep blocked-by <id>" >&2; return 1
    fi

    local result
    result=$(_get "/deps/$id/blocked-by")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Issues blocking $id:"
        echo "$result" | _jq -r '.[]? | "  → " + .dependsOnId' 2>/dev/null || echo "  (none)"
    fi
}

# ── Epic commands ────────────────────────────────────────────────────────────

cmd_epic() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list)    cmd_epic_list "$@" ;;
        tree)    cmd_epic_tree "$@" ;;
        subtask) cmd_epic_subtask "$@" ;;
        --help|-h|help)
            echo "Usage: taskstackai epic <list|tree|subtask> ..."
            echo ""
            echo "  taskstackai epic list              List all epics"
            echo "  taskstackai epic tree <id>         Show epic tree"
            echo "  taskstackai epic subtask <id>      Create subtask under epic"
            ;;
        *) echo "Unknown epic subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_epic_list() {
    local json_flag=false
    [[ "${1:-}" == "--json" ]] && json_flag=true

    local result
    result=$(_get "/epics")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Epics:"
        echo ""
        echo "$result" | _jq -r '.[]? | (.status | if . == "open" then "○" elif . == "in_progress" then "◐" elif . == "closed" then "✓" else "?" end) + " " + .id + " " + .title + " (" + (.completionPercent|tostring) + "% complete, " + (.childCount|tostring) + " children)"' 2>/dev/null || echo "  (none)"
    fi
}

cmd_epic_tree() {
    local id="${1:-}" json_flag=false
    [[ "${2:-}" == "--json" ]] && json_flag=true

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai epic tree <epic-id>" >&2; return 1
    fi

    local result
    result=$(_get "/epics/$id/tree")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "$result" | _jq -r '
            def render(indent):
                (indent + (.status | if . == "open" then "○" elif . == "in_progress" then "◐" elif . == "closed" then "✓" else "?" end) + " " + .id + " " + .title),
                (.children[]? | render(indent + "  "));
            render("")
        ' 2>/dev/null
    fi
}

cmd_epic_subtask() {
    local parent_id="${1:-}" title="${2:-}" json_flag=false
    [[ "${3:-}" == "--json" ]] && json_flag=true

    if [[ -z "$parent_id" || -z "$title" ]]; then
        echo "Usage: taskstackai epic subtask <parent-id> \"<title>\"" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg title "$title" '{title: $title}')

    local result
    result=$(_post "/epics/$parent_id/subtasks" -d "$body")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        local id
        id=$(echo "$result" | _jq -r '.id')
        echo "✓ Created subtask: $id — $title (parent: $parent_id)"
    fi
}

# ── Label commands ───────────────────────────────────────────────────────────

cmd_label() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list)    cmd_label_list "$@" ;;
        create)  cmd_label_create "$@" ;;
        add)     cmd_label_add "$@" ;;
        rm|remove) cmd_label_rm "$@" ;;
        delete)  cmd_label_delete "$@" ;;
        --help|-h|help)
            echo "Usage: taskstackai label <list|create|add|rm|delete> ..."
            echo ""
            echo "  taskstackai label list                   List all labels"
            echo "  taskstackai label create <name> [color]   Create label"
            echo "  taskstackai label add <issue> <label-id>  Assign label to issue"
            echo "  taskstackai label rm <issue> <label-id>   Remove label from issue"
            echo "  taskstackai label delete <label-id>        Delete label"
            ;;
        *) echo "Unknown label subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_label_list() {
    local json_flag=false
    [[ "${1:-}" == "--json" ]] && json_flag=true

    local result
    result=$(_get "/labels")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Labels:"
        echo "$result" | _jq -r '.[]? | "  [" + (.id|tostring) + "] " + .name + " (" + .color + ")"' 2>/dev/null || echo "  (none)"
    fi
}

cmd_label_create() {
    local name="${1:-}" color="${2:-#6ea8fe}" json_flag=false
    [[ "${3:-}" == "--json" ]] && json_flag=true

    if [[ -z "$name" ]]; then
        echo "Usage: taskstackai label create <name> [color]" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg name "$name" --arg color "$color" \
        '{name: $name, color: $color}')

    local result
    result=$(_post "/labels" -d "$body")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "✓ Created label: $name ($color)"
    fi
}

cmd_label_add() {
    local issue_id="${1:-}" label_id="${2:-}"

    if [[ -z "$issue_id" || -z "$label_id" ]]; then
        echo "Usage: taskstackai label add <issue-id> <label-id>" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg i "$issue_id" --argjson l "$label_id" \
        '{issueId: $i, labelId: $l}')

    _post "/labels/assign" -d "$body" >/dev/null
    echo "✓ Added label $label_id to issue $issue_id"
}

cmd_label_rm() {
    local issue_id="${1:-}" label_id="${2:-}"

    if [[ -z "$issue_id" || -z "$label_id" ]]; then
        echo "Usage: taskstackai label rm <issue-id> <label-id>" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg i "$issue_id" --argjson l "$label_id" \
        '{issueId: $i, labelId: $l}')

    _delete "/labels/assign" -d "$body" >/dev/null
    echo "✓ Removed label $label_id from issue $issue_id"
}

cmd_label_delete() {
    local label_id="${1:-}"

    if [[ -z "$label_id" ]]; then
        echo "Usage: taskstackai label delete <label-id>" >&2; return 1
    fi

    _delete "/labels/$label_id" >/dev/null
    echo "✓ Deleted label $label_id"
}

# ── Comment commands ─────────────────────────────────────────────────────────

