    local result
    result=$(_get "/events?page=${page}&pageSize=25")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Recent Activity:"
        echo ""
        echo "$result" | _jq -r '.items[]? | "  " + .createdAt + " " + .actorId + " " + .action + " " + .issueId + (if .newValue then " → " + .newValue else "" end)' 2>/dev/null || echo "  (none)"
    fi
}

