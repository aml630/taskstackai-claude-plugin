# ── Swarm commands ────────────────────────────────────────────────────────────

cmd_swarm() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        create)      cmd_swarm_create "$@" ;;
        status)      cmd_swarm_status "$@" ;;
        ready)       cmd_swarm_ready "$@" ;;
        validate)    cmd_swarm_validate "$@" ;;
        list)        cmd_swarm_list "$@" ;;
        --help|-h|help)
            cat <<'EOF'
Usage: taskstackai swarm <subcommand> [options]

  create <epic-id>       Create a swarm from an epic
  status <id>            Show swarm status with wave breakdown
  ready <id>             Show ready front (unblocked steps)
  validate <epic-id>     Validate an epic for swarming
  list                   List active swarms
EOF
            ;;
        *) echo "Unknown swarm subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_swarm_create() {
    local epic_id="" coordinator="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --coordinator) coordinator="$2"; shift 2 ;;
            --json)        json_flag=true; shift ;;
            --help|-h)     echo "Usage: taskstackai swarm create <epic-id> [--coordinator <user-id>] [--json]"; return 0 ;;
            *)             epic_id="$1"; shift ;;
        esac
    done

    if [[ -z "$epic_id" ]]; then
        echo "Usage: taskstackai swarm create <epic-id>" >&2; return 1
    fi

    local body
    body=$(printf '{"epicIssueId":"%s"%s}' \
        "$epic_id" \
        "$(if [[ -n "$coordinator" ]]; then printf ',"coordinatorId":"%s"' "$coordinator"; fi)")

    local result
    result=$(_post "/swarm/create" -d "$body") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '"✓ Created swarm " + .id + " - " + .title + " (" + (.totalSteps|tostring) + " steps)"'
}

cmd_swarm_status() {
    local id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai swarm status <id> [--json]"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai swarm status <id>" >&2; return 1
    fi

    local result
    result=$(_get "/swarm/$id/status") || { echo "Swarm '$id' not found." >&2; return 1; }

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '
        "╔══════════════════════════════════════════════════════════════",
        "║ Swarm Status: " + .moleculeId,
        "╠══════════════════════════════════════════════════════════════",
        "║ Total:         " + (.totalSteps|tostring) + " steps",
        "║ Completed:     " + (.completedSteps|tostring),
        "║ In Progress:   " + (.inProgressSteps|tostring),
        "║ Max Parallel:  " + (.maxParallelism|tostring),
        (if .velocity then "║ Velocity:      " + (.velocity|tostring) + " steps/hour" else empty end),
        (if .estimatedCompletion then "║ ETA:           " + .estimatedCompletion else empty end),
        "╠══ Waves ═════════════════════════════════════════════════════",
        (.waves // [] | .[] |
            "║  Wave " + (.waveNumber|tostring) + ": " +
            (.completedSteps|tostring) + "/" + (.totalSteps|tostring) + " completed, " +
            (.inProgressSteps|tostring) + " in progress"
        ),
        "╠══ Ready Front ═══════════════════════════════════════════════",
        (if (.readyFront | length) > 0 then
            (.readyFront[] |
                "║  " + (if .issueStatus == "in_progress" then "◐" else "○" end) +
                " " + .issueId + " " + .issueTitle +
                " (W" + (.wave|tostring) + ")"
            )
        else
            "║  No steps ready."
        end),
        "╚══════════════════════════════════════════════════════════════"'
}

cmd_swarm_ready() {
    local id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai swarm ready <id> [--json]"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai swarm ready <id>" >&2; return 1
    fi

    local result
    result=$(_get "/swarm/$id/ready-fronts") || { echo "Swarm '$id' not found." >&2; return 1; }

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "Ready front for swarm $id:"
    echo "$result" | _jq -r '.[] |
        "  " + (if .issueStatus == "in_progress" then "◐" else "○" end) +
        " " + .issueId + " [W" + (.wave|tostring) + "] " + .issueTitle'
}

cmd_swarm_validate() {
    local epic_id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai swarm validate <epic-id> [--json]"; return 0 ;;
            *)         epic_id="$1"; shift ;;
        esac
    done

    if [[ -z "$epic_id" ]]; then
        echo "Usage: taskstackai swarm validate <epic-id>" >&2; return 1
    fi

    local result
    result=$(_get "/swarm/$epic_id/validate") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '
        (if .isValid then "✓ Epic is valid for swarming" else "✗ Epic has issues:" end),
        (.errors // [] | .[] | "  ERROR: " + .),
        (.warnings // [] | .[] | "  WARN:  " + .)'
}

cmd_swarm_list() {
    local json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai swarm list [--json]"; return 0 ;;
            *)         shift ;;
        esac
    done

    local result
    result=$(_get "/swarm/list") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "Active swarms:"
    echo "$result" | _jq -r '.[] |
        "  " + (if .status == "open" then "○" elif .status == "in_progress" then "◐" else "?" end) +
        " " + .id + " [" + .phase + "] " + .title +
        " (" + (.completedSteps|tostring) + "/" + (.totalSteps|tostring) + " steps)"'
}

# ── Bond commands ─────────────────────────────────────────────────────────────

cmd_bond() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        create)  cmd_bond_create "$@" ;;
        list)    cmd_bond_list "$@" ;;
        delete)  cmd_bond_delete "$@" ;;
        --help|-h|help)
            cat <<'EOF'
Usage: taskstackai bond <subcommand> [options]

  create     Create a bond between two molecules
  list       List bonds (optionally for a specific molecule)
  delete     Delete a bond
EOF
            ;;
        *) echo "Unknown bond subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_bond_create() {
    local source="" target="" bond_type="sequential" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --source)  source="$2"; shift 2 ;;
            --target)  target="$2"; shift 2 ;;
            --type)    bond_type="$2"; shift 2 ;;
            --json)    json_flag=true; shift ;;
            --help|-h) echo "Usage: taskstackai bond create --source <id> --target <id> [--type <sequential|parallel|conditional>] [--json]"; return 0 ;;
            *)         shift ;;
        esac
    done

    if [[ -z "$source" || -z "$target" ]]; then
        echo "Usage: taskstackai bond create --source <mol-id> --target <mol-id>" >&2; return 1
    fi

    local body
    body=$(printf '{"sourceId":"%s","targetId":"%s","bondType":"%s"}' "$source" "$target" "$bond_type")

    local result
    result=$(_post "/bonds" -d "$body") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "$result" | _jq -r '"✓ Created bond #" + (.id|tostring) + ": " + .sourceMoleculeTitle + " → " + .targetMoleculeTitle + " [" + .bondType + "]"'
}

cmd_bond_list() {
    local molecule_id="" json_flag=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --molecule) molecule_id="$2"; shift 2 ;;
            --json)     json_flag=true; shift ;;
            --help|-h)  echo "Usage: taskstackai bond list [--molecule <id>] [--json]"; return 0 ;;
            *)          shift ;;
        esac
    done

    local path="/bonds"
    [[ -n "$molecule_id" ]] && path="${path}?moleculeId=$molecule_id"

    local result
    result=$(_get "$path") || return 1

    if $json_flag; then
        echo "$result" | _jq '.'
        return
    fi

    echo "Bonds:"
    echo "$result" | _jq -r '.[] |
        "  #" + (.id|tostring) + " " + .sourceMoleculeTitle + " → " + .targetMoleculeTitle + " [" + .bondType + "]"'
}

cmd_bond_delete() {
    local id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) echo "Usage: taskstackai bond delete <bond-id>"; return 0 ;;
            *)         id="$1"; shift ;;
        esac
    done

    if [[ -z "$id" ]]; then
        echo "Usage: taskstackai bond delete <bond-id>" >&2; return 1
    fi

    _delete "/bonds/$id" >/dev/null || { echo "Failed to delete bond." >&2; return 1; }
    echo "✓ Deleted bond #$id"
}

# ── Version ──────────────────────────────────────────────────────────────────

cmd_ie() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true
    case "$subcmd" in
        export)  cmd_ie_export "$@" ;;
        import)  cmd_ie_import "$@" ;;
        preview) cmd_ie_preview "$@" ;;
        help|--help|-h)
            echo "Usage: taskstackai ie <subcommand>"
            echo ""
            echo "Subcommands:"
            echo "  export [--status open] [-o file.jsonl]   Export issues as JSONL"
            echo "  import <file> --format <fmt>             Import issues from file"
            echo "  preview <file> --format <fmt>            Preview import file"
            echo ""
            echo "Formats: taskstackai, github_csv, jira_csv, linear_csv"
            ;;
        *)
            echo "Unknown ie subcommand: $subcmd" >&2
            exit 1
            ;;
    esac
}

cmd_ie_export() {
    local status="" output=""
    local comments="true" labels="true" deps="true"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)  status="$2"; shift 2 ;;
            -o|--output) output="$2"; shift 2 ;;
            --no-comments) comments="false"; shift ;;
            --no-labels)   labels="false"; shift ;;
            --no-deps)     deps="false"; shift ;;
            *) shift ;;
        esac
    done

    local body
    body=$(printf '{"format":"jsonl","includeComments":%s,"includeLabels":%s,"includeDependencies":%s' "$comments" "$labels" "$deps")
    if [[ -n "$status" ]]; then
        body="$body,\"status\":\"$status\""
    fi
    body="$body}"

    if [[ -n "$output" ]]; then
        _post "/import-export/export" -d "$body" > "$output"
        echo "Exported to $output"
    else
        _post "/import-export/export" -d "$body"
    fi
}

cmd_ie_import() {
    local file="${1:-}"
    shift 2>/dev/null || true
    local format="taskstackai" dry_run="false"
    local project_id="${TASKSTACKAI_PROJECT_ID:-}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --format)    format="$2"; shift 2 ;;
            --project)   project_id="$2"; shift 2 ;;
            --dry-run)   dry_run="true"; shift ;;
            *) shift ;;
        esac
    done

    if [[ -z "$file" || ! -f "$file" ]]; then
        echo "Usage: taskstackai ie import <file> --format <fmt> [--dry-run]" >&2
        return 1
    fi

    if [[ -z "$project_id" ]]; then
        echo "Error: No project ID. Set TASKSTACKAI_PROJECT_ID or use --project <id>." >&2
        return 1
    fi

    local url="${TASKSTACKAI_SERVER:-https://taskstackai.com}/api/v1/import-export/import"
    local result
    result=$(curl -s -S --fail-with-body \
        -H "Authorization: Bearer ${TASKSTACKAI_API_KEY}" \
        -F "file=@${file}" \
        -F "format=${format}" \
        -F "projectId=${project_id}" \
        -F "dryRun=${dry_run}" \
        "$url" 2>/dev/null) || {
        echo "Error: Import API request failed" >&2
        return 1
    }

    echo "$result" | _jq -r '"Import complete: \(.imported) imported, \(.skipped) skipped, \(.total) total" + if (.errors | length) > 0 then "\nErrors:" else "" end'
    echo "$result" | _jq -r '.errors[]? | "  Row \(.row): \(.message)"'
}

cmd_ie_preview() {
    local file="${1:-}"
    shift 2>/dev/null || true
    local format="taskstackai"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --format) format="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [[ -z "$file" || ! -f "$file" ]]; then
        echo "Usage: taskstackai ie preview <file> --format <fmt>" >&2
        return 1
    fi

    local url="${TASKSTACKAI_SERVER:-https://taskstackai.com}/api/v1/import-export/import/preview"
    local result
    result=$(curl -s -S --fail-with-body \
        -H "Authorization: Bearer ${TASKSTACKAI_API_KEY}" \
        -F "file=@${file}" \
        -F "format=${format}" \
        "$url" 2>/dev/null) || {
        echo "Error: Preview API request failed" >&2
        return 1
    }

    echo "$result" | _jq -r '"Total rows: \(.totalRows)\nColumns: \(.detectedColumns | join(", "))"'
    echo ""
    echo "$result" | _jq -r '.previewRows[]? | to_entries | map("\(.key): \(.value)") | join(" | ")'
}

cmd_dup() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true
    case "$subcmd" in
        check)  cmd_dup_check "$@" ;;
        scan)   cmd_dup_scan "$@" ;;
        mark)   cmd_dup_mark "$@" ;;
        unmark) cmd_dup_unmark "$@" ;;
        help|--help|-h)
            echo "Usage: taskstackai dup <subcommand>"
            echo ""
            echo "Subcommands:"
            echo "  check <title>              Check for duplicates by title text"
            echo "  scan [--status open]       Scan backlog for potential duplicates"
            echo "  mark <issue-id> <orig-id>  Mark issue as duplicate of another"
            echo "  unmark <issue-id>          Remove duplicate marking"
            ;;
        *)
            echo "Unknown dup subcommand: $subcmd" >&2
            exit 1
            ;;
    esac
}

cmd_dup_check() {
    local title="$*"
    if [[ -z "$title" ]]; then
        echo "Usage: taskstackai dup check <title text>" >&2
        return 1
    fi

    local body
    body=$(printf '{"title":"%s"}' "$(echo "$title" | sed 's/"/\\"/g')")

    local result
    result=$(_post "/issues/duplicates/check" -d "$body")

    echo "$result" | _jq -r '
        if (.items | length) == 0 then "No duplicates found."
        else .items[] | "\(.score)%  \(.issueId)  [\(.status)]  \(.title)"
        end'
}

cmd_dup_scan() {
    local status="open"
    local min_score="50"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)  status="$2"; shift 2 ;;
            --min-score) min_score="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local path="/duplicates/scan?status=${status}&minScore=${min_score}&pageSize=50"
    local result
    result=$(_get "$path")

    echo "$result" | _jq -r '
        if (.items | length) == 0 then "No potential duplicates found."
        else .items[] |
            "── \(.issue.id) [\(.issue.status)] \(.issue.title)" ,
            (.candidates[] | "   └─ \(.score)%  \(.issueId) [\(.status)] \(.title)"),
            ""
        end'
}

cmd_dup_mark() {
    local issue_id="${1:-}"
    local canonical_id="${2:-}"

    if [[ -z "$issue_id" || -z "$canonical_id" ]]; then
        echo "Usage: taskstackai dup mark <issue-id> <canonical-id>" >&2
        return 1
    fi

    local body
    body=$(printf '{"duplicateOfId":"%s"}' "$canonical_id")

    local result
    result=$(_post "/issues/${issue_id}/mark-duplicate" -d "$body")

    echo "$result" | _jq -r '"Marked \(.id) as duplicate of " + (.duplicateOfId // "unknown")'
}

cmd_dup_unmark() {
    local issue_id="${1:-}"

    if [[ -z "$issue_id" ]]; then
        echo "Usage: taskstackai dup unmark <issue-id>" >&2
        return 1
    fi

    local result
    result=$(_post "/issues/${issue_id}/unmark-duplicate" -d '{}')

    echo "$result" | _jq -r '"Unmarked \(.id) as duplicate. Status: \(.status)"'
}

cmd_orphan() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true
    case "$subcmd" in
        scan)     cmd_orphan_scan "$@" ;;
        fix)      cmd_orphan_fix "$@" ;;
        fix-all)  cmd_orphan_fix_all "$@" ;;
        help|--help|-h)
            echo "Usage: taskstackai orphan <subcommand>"
            echo ""
            echo "Subcommands:"
            echo "  scan              Scan for orphaned references"
            echo "  fix <type> <id>   Fix a single orphan (type: broken_parent|dangling_dependency|deleted_project)"
            echo "  fix-all           Fix all detected orphans"
            ;;
        *)
            echo "Unknown orphan subcommand: $subcmd" >&2
            exit 1
            ;;
    esac
}

cmd_orphan_scan() {
    local result
    result=$(_get "/orphans")

    echo "$result" | _jq -r '
        if (.totalCount // 0) == 0 then "No orphans detected. All references are healthy."
        else
            "Found \(.totalCount) orphan(s) (scanned at \(.scannedAt))\n",
            (.orphans[] |
                "  [\(.orphanType | gsub("_";" "))]  \(.issueId)  \(.issueTitle // "<unknown>")  →  broken ref: \(.brokenRefId)" +
                (if .dependencyId then "  (dep #\(.dependencyId))" else "" end)
            )
        end'
}

cmd_orphan_fix() {
    local orphan_type="${1:-}"
    local issue_id="${2:-}"

    if [[ -z "$orphan_type" || -z "$issue_id" ]]; then
        echo "Usage: taskstackai orphan fix <orphan_type> <issue_id> [--dep-id N] [--target-project ID]" >&2
        return 1
    fi

    shift 2
    local dep_id=""
    local target_project=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dep-id)        dep_id="$2"; shift 2 ;;
            --target-project) target_project="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local body
    body="{\"issueId\":\"${issue_id}\",\"orphanType\":\"${orphan_type}\",\"fixAction\":\"remove_ref\""
    if [[ -n "$dep_id" ]]; then
        body="${body},\"dependencyId\":${dep_id}"
    fi
    if [[ -n "$target_project" ]]; then
        body="${body},\"fixAction\":\"reassign_project\",\"targetProjectId\":\"${target_project}\""
    fi
    body="${body}}"

    local result
    result=$(_post "/orphans/fix" -d "$body")

    echo "$result" | _jq -r 'if .success then "Fixed: \(.message)" else "Failed: \(.message // .error)" end'
}

cmd_orphan_fix_all() {
    local result
    result=$(_post "/orphans/fix-all" -d '{}')

    echo "$result" | _jq -r '"Fixed: \(.fixed), Failed: \(.failed)" + (if (.errors | length) > 0 then "\nErrors:\n" + (.errors[] | "  - \(.)") else "" end)'
}

cmd_setup() {
    local api_key=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --key)  api_key="$2"; shift 2 ;;
            *)      shift ;;
        esac
    done

    if [[ -z "$api_key" ]]; then
        echo "TaskStackAi Setup"
        echo "================="
        echo ""
        echo "Enter your API key (from https://taskstackai.com/api-keys):"
        read -r api_key
    fi

    if [[ -z "$api_key" ]]; then
        echo "Error: API key cannot be empty." >&2
        exit 1
    fi

    # Validate the key
    local server="${TASKSTACKAI_SERVER:-https://taskstackai.com}"
    local response
    response=$(curl -s -S -X GET \
        -H "Authorization: Bearer ${api_key}" \
        -H "Accept: application/json" \
        --fail-with-body \
        "${server}/api/v1/projects" 2>/dev/null)

    if [[ $? -ne 0 ]]; then
        echo "Error: Invalid API key or server unreachable." >&2
        exit 1
    fi

    # Write config
    mkdir -p .taskstackai
    cat > .taskstackai/config <<CONF
TASKSTACKAI_API_KEY="${api_key}"
CONF

    # Write AGENTS.md if it doesn't exist
    if [[ ! -f "AGENTS.md" ]]; then
        local plugin_dir
        plugin_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
        local agents_template="${plugin_dir}/skills/taskstackai/resources/AGENTS.md"
        if [[ -f "$agents_template" ]]; then
            cp -f "$agents_template" AGENTS.md
            echo "✓ Created AGENTS.md (AI agent instructions)"
        fi
    else
        echo "• AGENTS.md already exists — skipping"
    fi

    # Append TaskStackAi block to CLAUDE.md if not already present
    if [[ -f "CLAUDE.md" ]]; then
        if ! grep -q "BEGIN TASKSTACKAI INTEGRATION" CLAUDE.md 2>/dev/null; then
            cat >> CLAUDE.md <<'CLAUDEBLOCK'

<!-- BEGIN TASKSTACKAI INTEGRATION v:2 -->
## TaskStackAi Issue Tracker

This project uses **TaskStackAi** for ALL issue tracking. Run `taskstackai prime` to see full workflow context and commands.

### Quick Reference

```bash
# Core workflow
taskstackai ready                           # Find available work
taskstackai show <id>                       # View issue details (--long for full)
taskstackai claim <id>                      # Claim work
taskstackai close <id> --reason "Done"      # Complete work
taskstackai create "Title" -t task -p 2     # Create an issue
taskstackai update <id> --title "New title" # Update fields inline
taskstackai list                            # List all issues
taskstackai search "query"                  # Full-text search

# Dependencies
taskstackai dep add <id> <depends-on-id>    # Add dependency
taskstackai dep rm <id> <depends-on-id>     # Remove dependency

# Epics
taskstackai update <id> --type epic         # Promote issue to epic
taskstackai epic subtask <epic-id> "Title"  # Create NEW subtask (takes a title, NOT an existing issue ID)
taskstackai epic tree <epic-id>             # Show epic tree view

# Labels & Comments
taskstackai label add <issue-id> <label>    # Assign label to issue
taskstackai comment add <id> "text"         # Add comment to issue
```

### Rules

- Use `taskstackai` for ALL task tracking — do NOT use TodoWrite, TaskCreate, or markdown TODO lists
- Run `taskstackai prime` for detailed command reference and session close protocol
- Always claim issues before starting work: `taskstackai claim <id>`

## Landing the Plane (Session Completion)

**When ending a work session**, you MUST complete ALL steps below. Work is NOT complete until `git push` succeeds.

**MANDATORY WORKFLOW:**

1. **File issues for remaining work** - Create issues for anything that needs follow-up
2. **Run quality gates** (if code changed) - Tests, linters, builds
3. **Update issue status** - Close finished work, update in-progress items
4. **PUSH TO REMOTE** - This is MANDATORY:
   ```bash
   git pull --rebase
   git push
   git status  # MUST show "up to date with origin"
   ```
5. **Clean up** - Clear stashes, prune remote branches
6. **Verify** - All changes committed AND pushed
7. **Hand off** - Provide context for next session

**CRITICAL RULES:**
- Work is NOT complete until `git push` succeeds
- NEVER stop before pushing - that leaves work stranded locally
- NEVER say "ready to push when you are" - YOU must push
- If push fails, resolve and retry until it succeeds
<!-- END TASKSTACKAI INTEGRATION -->
CLAUDEBLOCK
            echo "✓ Appended TaskStackAi instructions to CLAUDE.md"
        else
            echo "• CLAUDE.md already has TaskStackAi integration — skipping"
        fi
    fi

    # Add .taskstackai/ to .gitignore if not already there
    if [[ -f ".gitignore" ]]; then
        if ! grep -qx '.taskstackai/' .gitignore 2>/dev/null; then
            echo '.taskstackai/' >> .gitignore
        fi
    else
        echo '.taskstackai/' > .gitignore
    fi

    echo ""
    echo "✓ Setup complete! Config saved to .taskstackai/config"
    echo ""
    echo "Try these commands:"
    echo "  taskstackai ready      # see what's ready to work on"
    echo "  taskstackai create     # create a new issue"
    echo "  taskstackai list       # list all issues"
}

cmd_remove() {
    echo "TaskStackAi Removal"
    echo "==================="
    echo ""

    local removed=false

    # Remove .taskstackai/ directory
    if [[ -d ".taskstackai" ]]; then
        rm -rf .taskstackai
        echo "✓ Removed .taskstackai/ directory"
        removed=true
    fi

    # Remove AGENTS.md if it mentions TaskStackAi
    if [[ -f "AGENTS.md" ]] && grep -q "TaskStackAi" AGENTS.md 2>/dev/null; then
        rm -f AGENTS.md
        echo "✓ Removed AGENTS.md"
        removed=true
    fi

    # Remove TaskStackAi block from CLAUDE.md
    if [[ -f "CLAUDE.md" ]] && grep -q "BEGIN TASKSTACKAI INTEGRATION" CLAUDE.md 2>/dev/null; then
        sed '/<!-- BEGIN TASKSTACKAI INTEGRATION/,/<!-- END TASKSTACKAI INTEGRATION -->/d' CLAUDE.md > CLAUDE.md.tmp && mv -f CLAUDE.md.tmp CLAUDE.md
        echo "✓ Removed TaskStackAi integration from CLAUDE.md"
        removed=true
    fi

    # Clean .taskstackai/ from .gitignore
    if [[ -f ".gitignore" ]] && grep -q '.taskstackai/' .gitignore 2>/dev/null; then
        grep -v '.taskstackai/' .gitignore > .gitignore.tmp && mv -f .gitignore.tmp .gitignore
        echo "✓ Removed .taskstackai/ from .gitignore"
        removed=true
    fi

    if $removed; then
        echo ""
        echo "✓ TaskStackAi has been removed from this project."
    else
        echo "Nothing to remove — TaskStackAi is not initialized in this directory."
    fi
}

cmd_delete() {
    local issue_id="${1:?Usage: taskstackai delete <issue-id>}"
    _delete "/issues/${issue_id}" | _jq -r '"✓ Deleted issue: " + .id'
}

cmd_version() {
    echo "taskstackai $TASKSTACKAI_VERSION (TaskStackAi CLI)"
}

# ── Help ─────────────────────────────────────────────────────────────────────

cmd_help() {
    cat <<'HELP'
taskstackai - TaskStackAi CLI

Usage: taskstackai <command> [options]

Core Commands:
  setup             Set up project config with API key
  remove            Remove TaskStackAi from this project
  prime             Show workflow context (for AI session start)
  version           Show version

Issue Tracking:
  ready             Show unblocked issues ready to work
  create            Create a new issue
  show <id>         Show issue details (--long for full)
  list              List/filter issues
  update <id>       Update an issue
  delete <id>       Delete an issue
  close <id>        Close issue(s)
  reopen <id>       Reopen a closed issue
  claim <id>        Claim issue (assign + set in_progress)
  search <query>    Full-text search
  blocked           Show blocked issues

Dependencies:
  dep add           Add dependency between issues
  dep rm            Remove dependency
  dep blocks        Show what an issue blocks
  dep blocked-by    Show what blocks an issue

Epics:
  epic list         List all epics
  epic tree <id>    Show epic tree view
  epic subtask      Create subtask under epic

Labels:
  label list        List all labels
  label create      Create a label
  label add         Assign label to issue
  label rm          Remove label from issue
  label delete      Delete a label

Comments:
  comment add       Add comment to issue
  comment list      List comments on issue
  comment edit      Edit a comment
  comment delete    Delete a comment

Events:
  event list        Org-wide activity feed
  event issue <id>  Events for a specific issue

Dashboard:
  dashboard stats      Project statistics
  dashboard burndown   Burndown chart data
  dashboard velocity   Velocity chart data
  dashboard activity   Recent activity

Data:
  export            Export all issues to JSON
  import <file>     Import issues from JSON

Project:
  project members   List project members
  project invite    Invite a member to the project

API Keys:
  apikey list       List API keys
  apikey create     Create new API key
  apikey delete     Delete an API key
  stats             Quick project stats

Global Options:
  --json            Output raw JSON
  --help, -h        Show help

Config: .taskstackai/config (API key stored in TASKSTACKAI_API_KEY)
HELP
}

# ── Main dispatch ────────────────────────────────────────────────────────────

_load_config "${1:-}"

case "${1:-help}" in
    setup)     shift; cmd_setup "$@" ;;
    init)      shift; cmd_init "$@" ;;
    remove)    shift; cmd_remove "$@" ;;
    prime)     shift; cmd_prime "$@" ;;
    ready)     shift; cmd_ready "$@" ;;
    create)    shift; cmd_create "$@" ;;
    show)      shift; cmd_show "$@" ;;
    list)      shift; cmd_list "$@" ;;
    update)    shift; cmd_update "$@" ;;
    delete)    shift; cmd_delete "$@" ;;
    close)     shift; cmd_close "$@" ;;
    reopen)    shift; cmd_reopen "$@" ;;
    claim)     shift; cmd_claim "$@" ;;
    search)    shift; cmd_search "$@" ;;
    stats)     shift; cmd_stats "$@" ;;
    blocked)   shift; cmd_blocked "$@" ;;
    dep)       shift; cmd_dep "$@" ;;
    epic)      shift; cmd_epic "$@" ;;
    label)     shift; cmd_label "$@" ;;
    comment)   shift; cmd_comment "$@" ;;
    event)     shift; cmd_event "$@" ;;
    dashboard) shift; cmd_dashboard "$@" ;;
    export)    shift; cmd_export "$@" ;;
    import)    shift; cmd_import "$@" ;;
    project)   shift; cmd_project "$@" ;;
    apikey)    shift; cmd_apikey "$@" ;;
    ie)        shift; cmd_ie "$@" ;;
    # MVP-HIDDEN: org)       shift; cmd_org "$@" ;;
    # MVP-HIDDEN: mol)       shift; cmd_mol "$@" ;;
    # MVP-HIDDEN: swarm)     shift; cmd_swarm "$@" ;;
    # MVP-HIDDEN: bond)      shift; cmd_bond "$@" ;;
    # MVP-HIDDEN: orphan)    shift; cmd_orphan "$@" ;;
    # MVP-HIDDEN: dup)       shift; cmd_dup "$@" ;;
    version)   cmd_version ;;
    help|--help|-h) cmd_help ;;
    *)         echo "Unknown command: $1. Run 'taskstackai help' for usage." >&2; exit 1 ;;
esac
