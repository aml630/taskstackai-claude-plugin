    else
        echo "Events for $id:"
        echo ""
        echo "$result" | _jq -r '.[]? | "  " + .createdAt + " " + .actorId + " " + .action + (if .oldValue then " (" + .oldValue + " → " + .newValue + ")" else "" end)' 2>/dev/null || echo "  (none)"
    fi
}

