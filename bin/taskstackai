    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        add)     cmd_comment_add "$@" ;;
        list)    cmd_comment_list "$@" ;;
        edit)    cmd_comment_edit "$@" ;;
        delete)  cmd_comment_delete "$@" ;;
        --help|-h|help)
            echo "Usage: taskstackai comment <add|list|edit|delete> ..."
            echo ""
            echo "  taskstackai comment add <issue-id> \"text\"   Add comment"
            echo "  taskstackai comment list <issue-id>          List comments"
            echo "  taskstackai comment edit <comment-id> \"text\" Edit comment"
            echo "  taskstackai comment delete <comment-id>       Delete comment"
            ;;
        *) echo "Unknown comment subcommand: $subcmd" >&2; return 1 ;;
    esac
}

cmd_comment_add() {
    local issue_id="${1:-}" body_text="${2:-}" json_flag=false
    [[ "${3:-}" == "--json" ]] && json_flag=true

    if [[ -z "$issue_id" || -z "$body_text" ]]; then
        echo "Usage: taskstackai comment add <issue-id> \"comment text\"" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg i "$issue_id" --arg b "$body_text" \
        '{issueId: $i, body: $b}')

    local result
    result=$(_post "/comments" -d "$body")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "✓ Comment added to $issue_id"
    fi
}

cmd_comment_list() {
    local issue_id="${1:-}" json_flag=false
    [[ "${2:-}" == "--json" ]] && json_flag=true

    if [[ -z "$issue_id" ]]; then
        echo "Usage: taskstackai comment list <issue-id>" >&2; return 1
    fi

    local result
    result=$(_get "/comments/$issue_id")

    if $json_flag; then
        echo "$result" | _jq '.'
    else
        echo "Comments for $issue_id:"
        echo ""
        echo "$result" | _jq -r '.[]? | "  " + .authorName + " (" + .createdAt + "):\n    " + .body + "\n"' 2>/dev/null || echo "  (none)"
    fi
}

cmd_comment_edit() {
    local comment_id="${1:-}" body_text="${2:-}"

    if [[ -z "$comment_id" || -z "$body_text" ]]; then
        echo "Usage: taskstackai comment edit <comment-id> \"new text\"" >&2; return 1
    fi

    local body
    body=$(_jq -n --arg b "$body_text" '{body: $b}')

    _patch "/comments/$comment_id" -d "$body" >/dev/null
    echo "✓ Comment $comment_id updated"
}

cmd_comment_delete() {
    local comment_id="${1:-}"

    if [[ -z "$comment_id" ]]; then
        echo "Usage: taskstackai comment delete <comment-id>" >&2; return 1
    fi

    _delete "/comments/$comment_id" >/dev/null
    echo "✓ Comment $comment_id deleted"
}

